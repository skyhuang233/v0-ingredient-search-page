# ==============================================================
# 一键部署环境变量配置模板
# 使用方法：复制本文件为 .env.local，然后填入你自己的值
#   cp .env.example .env.local
# ==============================================================

# --- [必填] 模型路径配置 ---
# Qwen3-Embedding-0.6B 模型所在的父目录路径（容器会挂载整个目录）
# Windows 示例：MODEL_DIR=D:/models
# Linux/macOS 示例：MODEL_DIR=/home/yourname/models
MODEL_DIR=/path/to/your/models/parent/directory

# --- [必填] AI & LLM 配置 ---
# 用于 Chat 流式对话、Recommender 和 Agent 逻辑的 Gemini API Key
# 申请地址：https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- [可选] Google Cloud Vision API Key ---
# 用于图片食材识别功能，不填则该功能不可用
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# --- [必填] 数据库 (Supabase) 配置 ---
# 在 https://supabase.com 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_KEY=your_service_role_key

# --- [可选] 网络代理配置 ---
# 如果你的网络无法直接访问 Google API，请填入代理地址
# 注意：在 Docker 容器内，127.0.0.1 指向容器自身，而非宿主机！
# Docker Desktop (Windows/Mac) 可使用 host.docker.internal 替代 127.0.0.1
# 示例：HTTPS_PROXY=http://host.docker.internal:7897
HTTPS_PROXY=
HTTP_PROXY=

# --- [本地开发用，Docker 部署无需修改] ---
# 本地直接运行 Next.js 时使用此地址；Docker 部署时 compose 会自动覆盖它
RECOMMENDER_URL=http://localhost:8000/recommend
